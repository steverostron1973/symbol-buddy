---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import SymbolCard from '../../components/SymbolCard.astro';
import FAQAccordion from '../../components/FAQAccordion.jsx';
import CTA from '../../components/CTA.astro';
import { categories } from '../../data/categories.js';
import { symbols } from '../../data/symbols.js';

export function getStaticPaths() {
  return categories.map((category) => ({
    params: { slug: category.slug },
    props: { category },
  }));
}

const { category } = Astro.props;
const categorySymbols = symbols.filter((symbol) => symbol.category === category.slug);

const faqs = [
  {
    question: `What are ${category.name}?`,
    answer: `${category.name} are standardised icons and markings used to communicate important information at a glance. ${category.description}`,
  },
  {
    question: `Where will I see ${category.name}?`,
    answer: `You will encounter ${category.name.toLowerCase()} in everyday settings related to this topic — on labels, signage, equipment, packaging, or digital interfaces. SymbolBuddy explains each one so you know exactly what you are looking at.`,
  },
  {
    question: `How do I look up a specific symbol in ${category.name}?`,
    answer: `Use the search bar at the top of any SymbolBuddy page to find a symbol by name or keyword. You can also browse the grid below to explore every ${category.name.toLowerCase()} entry we have published in this category.`,
  },
  {
    question: `Are ${category.name} the same everywhere?`,
    answer: `Many ${category.name.toLowerCase()} follow international standards, but local regulations and manufacturer conventions can vary. SymbolBuddy notes regional differences where they matter and focuses on the most common versions you are likely to encounter.`,
  },
];
---

<Layout
  title={`${category.name} — SymbolBuddy`}
  description={`Explore all ${category.name.toLowerCase()} on SymbolBuddy. Plain-English explanations for every symbol, sign and marking.`}
>
  <Header />

  <main>
    <section class="px-4 py-10 sm:px-6 sm:py-14 lg:px-8">
      <div class="mx-auto max-w-6xl">
        <Breadcrumbs
          crumbs={[
            { label: 'Home', href: '/' },
            { label: 'Categories', href: '/categories' },
            { label: category.name },
          ]}
        />

        <div class="flex items-start gap-4 sm:gap-6">
          <span class="text-4xl sm:text-5xl" aria-hidden="true">{category.icon}</span>
          <div>
            <h1 class="font-heading text-3xl font-bold text-secondary sm:text-4xl lg:text-5xl">
              {category.name}
            </h1>
            <p class="mt-4 max-w-3xl text-base leading-relaxed text-secondary/70 sm:text-lg">
              {category.description}
            </p>
          </div>
        </div>

        {
          categorySymbols.length > 0 ? (
            <ul class="mt-12 grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
              {categorySymbols.map((symbol) => (
                <li class="list-none">
                  <SymbolCard
                    name={symbol.name}
                    slug={symbol.slug}
                    category={symbol.category}
                    meaning={symbol.meaning}
                    image={symbol.image}
                  />
                </li>
              ))}
            </ul>
          ) : (
            <div class="mt-12 rounded-2xl border border-slate-200/80 bg-card px-6 py-16 text-center shadow-sm">
              <p class="font-heading text-lg font-semibold text-secondary">
                We're adding symbols to this category soon. Check back shortly.
              </p>
              <p class="mt-2 text-sm text-secondary/70">
                In the meantime, try searching or browse another category.
              </p>
              <a
                href="/categories"
                class="mt-6 inline-flex items-center justify-center rounded-xl bg-primary px-6 py-3 text-sm font-semibold text-white transition-colors hover:bg-primary/90"
              >
                Browse all categories
              </a>
            </div>
          )
        }
      </div>
    </section>

    <section class="border-t border-slate-200/80 bg-white px-4 py-16 sm:px-6 sm:py-20 lg:px-8" aria-labelledby="category-faq-heading">
      <div class="mx-auto max-w-3xl">
        <h2 id="category-faq-heading" class="text-center font-heading text-2xl font-bold text-secondary sm:text-3xl">
          Frequently Asked Questions
        </h2>
        <div class="mt-10">
          <FAQAccordion faqs={faqs} client:visible />
        </div>
      </div>
    </section>

    <CTA />
  </main>

  <Footer />
</Layout>
