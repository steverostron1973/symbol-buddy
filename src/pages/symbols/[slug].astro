---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import SymbolCard from '../../components/SymbolCard.astro';
import FAQAccordion from '../../components/FAQAccordion.jsx';
import CTA from '../../components/CTA.astro';
import { categories } from '../../data/categories.js';
import { symbols } from '../../data/symbols.js';

export function getStaticPaths() {
  return symbols.map((symbol) => ({
    params: { slug: symbol.slug },
    props: { symbol },
  }));
}

const { symbol } = Astro.props;

const category = categories.find((cat) => cat.slug === symbol.category);
const categoryName = category?.name ?? symbol.category.replace(/-/g, ' ');

const relatedSymbols = symbols
  .filter((s) => s.category === symbol.category && s.slug !== symbol.slug)
  .slice(0, 4);

const faqs = [
  {
    question: `What does the ${symbol.name} mean?`,
    answer: `${symbol.meaning} ${symbol.description}`,
  },
  {
    question: `What should I do when I see the ${symbol.name}?`,
    answer: symbol.whatToDo,
  },
  {
    question: `Is the ${symbol.name} the same in every country?`,
    answer: `The ${symbol.name} is widely recognised, though labelling standards and local regulations can differ slightly by region. SymbolBuddy focuses on the most common version you are likely to see. If you spot a variation, compare it with the description and tags on this page for context.`,
  },
];
---

<Layout
  title={`${symbol.name} — What It Means | SymbolBuddy`}
  description={`Find out what the ${symbol.name} means, where you'll see it, and what to do. Plain-English explanation on SymbolBuddy.`}
>
  <Header />

  <main>
    <article class="px-4 py-10 sm:px-6 sm:py-14 lg:px-8">
      <div class="mx-auto max-w-4xl">
        <Breadcrumbs
          crumbs={[
            { label: 'Home', href: '/' },
            { label: 'Categories', href: '/categories' },
            { label: categoryName, href: `/categories/${symbol.category}` },
            { label: symbol.name },
          ]}
        />

        <header>
          <p class="text-sm font-semibold uppercase tracking-wide text-primary">
            {categoryName}
          </p>
          <h1 class="mt-2 font-heading text-3xl font-bold text-secondary sm:text-4xl lg:text-5xl">
            {symbol.name}
          </h1>
        </header>

        {
          symbol.image ? (
            <img
              src={symbol.image}
              alt={symbol.name}
              class="mt-8 aspect-video w-full rounded-2xl border border-slate-200/80 object-cover shadow-sm"
            />
          ) : (
            <div class="mt-8 flex aspect-video w-full items-center justify-center rounded-2xl border border-slate-200/80 bg-gradient-to-br from-slate-200 to-slate-100 shadow-sm">
              <p class="px-6 text-center font-heading text-xl font-bold text-secondary/60 sm:text-2xl">
                {symbol.name}
              </p>
            </div>
          )
        }

        <div class="mt-10 space-y-10">
          <section aria-labelledby="meaning-heading">
            <h2 id="meaning-heading" class="font-heading text-2xl font-bold text-secondary">
              What it means
            </h2>
            <p class="mt-3 text-base leading-relaxed text-secondary/80 sm:text-lg">
              {symbol.description}
            </p>
          </section>

          <section aria-labelledby="where-heading">
            <h2 id="where-heading" class="font-heading text-2xl font-bold text-secondary">
              Where you will see it
            </h2>
            <p class="mt-3 text-base leading-relaxed text-secondary/80 sm:text-lg">
              {symbol.whereYouSeeIt}
            </p>
          </section>

          <section aria-labelledby="what-to-do-heading">
            <h2 id="what-to-do-heading" class="font-heading text-2xl font-bold text-secondary">
              What you should do
            </h2>
            <p class="mt-3 text-base leading-relaxed text-secondary/80 sm:text-lg">
              {symbol.whatToDo}
            </p>
          </section>

          <section aria-labelledby="mistakes-heading">
            <h2 id="mistakes-heading" class="font-heading text-2xl font-bold text-secondary">
              Common mistakes
            </h2>
            <ul class="mt-4 space-y-3">
              {
                symbol.commonMistakes.map((mistake) => (
                  <li class="flex gap-3 text-base leading-relaxed text-secondary/80">
                    <span class="mt-2 h-1.5 w-1.5 shrink-0 rounded-full bg-accent" aria-hidden="true"></span>
                    {mistake}
                  </li>
                ))
              }
            </ul>
          </section>

          {
            symbol.tags.length > 0 && (
              <section aria-labelledby="tags-heading">
                <h2 id="tags-heading" class="font-heading text-2xl font-bold text-secondary">
                  Tags
                </h2>
                <ul class="mt-4 flex flex-wrap gap-2">
                  {
                    symbol.tags.map((tag) => (
                      <li class="list-none">
                        <span class="inline-block rounded-full bg-primary/10 px-4 py-1.5 text-sm font-medium text-primary">
                          {tag}
                        </span>
                      </li>
                    ))
                  }
                </ul>
              </section>
            )
          }
        </div>
      </div>
    </article>

    {
      relatedSymbols.length > 0 && (
        <section class="border-t border-slate-200/80 bg-white px-4 py-16 sm:px-6 sm:py-20 lg:px-8" aria-labelledby="related-heading">
          <div class="mx-auto max-w-6xl">
            <h2 id="related-heading" class="font-heading text-2xl font-bold text-secondary sm:text-3xl">
              Related Symbols
            </h2>
            <p class="mt-2 text-secondary/70">
              More symbols from {categoryName}.
            </p>
            <ul class="mt-10 grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-4">
              {
                relatedSymbols.map((related) => (
                  <li class="list-none">
                    <SymbolCard
                      name={related.name}
                      slug={related.slug}
                      category={related.category}
                      meaning={related.meaning}
                      image={related.image}
                    />
                  </li>
                ))
              }
            </ul>
          </div>
        </section>
      )
    }

    <section class="px-4 py-16 sm:px-6 sm:py-20 lg:px-8" aria-labelledby="symbol-faq-heading">
      <div class="mx-auto max-w-3xl">
        <h2 id="symbol-faq-heading" class="text-center font-heading text-2xl font-bold text-secondary sm:text-3xl">
          Frequently Asked Questions
        </h2>
        <div class="mt-10">
          <FAQAccordion faqs={faqs} client:visible />
        </div>
      </div>
    </section>

    <CTA />
  </main>

  <Footer />
</Layout>
