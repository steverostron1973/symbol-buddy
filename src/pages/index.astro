---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Hero from '../components/Hero.astro';
import CategoryCard from '../components/CategoryCard.astro';
import SymbolCard from '../components/SymbolCard.astro';
import FAQAccordion from '../components/FAQAccordion.jsx';
import CTA from '../components/CTA.astro';
import { categories } from '../data/categories.js';
import { symbols } from '../data/symbols.js';

const popularSymbols = symbols.slice(0, 8);

const helpFeatures = [
  {
    icon: '⚡',
    heading: 'Instant answers',
    text: 'Stop guessing what symbols mean. Get clear, plain-English explanations in seconds.',
  },
  {
    icon: '🌐',
    heading: 'Every symbol type',
    text: 'From laundry care labels to car dashboard lights, hazard signs to keyboard shortcuts.',
  },
  {
    icon: '✓',
    heading: 'Trusted information',
    text: 'Every symbol explained by experts, with real-world context and practical advice.',
  },
];

const trustPoints = [
  {
    text: '10,000+ symbols explained',
    icon: '📚',
  },
  {
    text: 'Updated regularly with new symbols',
    icon: '🔄',
  },
  {
    text: 'Written in plain, simple English',
    icon: '💬',
  },
  {
    text: 'Used by millions of people worldwide',
    icon: '🌍',
  },
];

const faqs = [
  {
    question: 'What is SymbolBuddy?',
    answer:
      'SymbolBuddy is a free online reference that explains everyday symbols, icons, warning lights, and codes in plain English. Whether you spotted a mystery mark on a clothing label or a flashing light on your dashboard, SymbolBuddy helps you understand what it means and what to do next.',
  },
  {
    question: 'Is SymbolBuddy free to use?',
    answer:
      'Yes. SymbolBuddy is completely free to browse and search. There are no subscriptions or sign-ups required to look up symbols and read our explanations.',
  },
  {
    question: 'How do I search for a symbol?',
    answer:
      'Type a keyword or phrase into the search bar at the top of the page — for example "tumble dry" or "check engine light". You can also browse by category if you know the general type of symbol you are looking for.',
  },
  {
    question: 'What types of symbols does SymbolBuddy cover?',
    answer:
      'SymbolBuddy covers laundry care labels, recycling codes, car dashboard warning lights, hazard and safety signs, keyboard shortcuts, electrical markings, packaging labels, medical symbols, travel signage, and DIY tool markings — with more added regularly.',
  },
  {
    question: 'How often is SymbolBuddy updated?',
    answer:
      'We add new symbols and refresh existing entries regularly as standards change and users request new topics. Category pages and popular symbol guides are reviewed to keep explanations accurate and up to date.',
  },
];
---

<Layout
  title="SymbolBuddy — Find Out What Any Symbol Means"
  description="Search thousands of symbols, icons, warning lights and signs. From laundry care labels to car dashboard lights — SymbolBuddy explains it all in plain English."
>
  <Header />

  <main>
    <Hero
      headline="Find out what any symbol means."
      subheading="Search thousands of symbols, icons and markings — from clothing labels to dashboard warning lights."
    />

    <!-- Browse by Category -->
    <section class="px-4 py-16 sm:px-6 sm:py-20 lg:px-8" aria-labelledby="categories-heading">
      <div class="mx-auto max-w-6xl">
        <div class="mx-auto max-w-2xl text-center">
          <h2 id="categories-heading" class="font-heading text-3xl font-bold text-secondary sm:text-4xl">
            Browse by Category
          </h2>
          <p class="mt-4 text-base leading-relaxed text-secondary/70 sm:text-lg">
            Choose a category to explore hundreds of symbols, signs and markings.
          </p>
        </div>

        <ul class="mt-12 grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {
            categories.map((category) => (
              <li class="list-none">
                <CategoryCard
                  title={category.name}
                  description={category.description}
                  slug={category.slug}
                  icon={category.icon}
                  count={category.count}
                />
              </li>
            ))
          }
        </ul>
      </div>
    </section>

    <!-- Popular Symbols -->
    <section class="bg-white px-4 py-16 sm:px-6 sm:py-20 lg:px-8" aria-labelledby="popular-heading">
      <div class="mx-auto max-w-6xl">
        <div class="mx-auto max-w-2xl text-center">
          <h2 id="popular-heading" class="font-heading text-3xl font-bold text-secondary sm:text-4xl">
            Popular Symbols
          </h2>
          <p class="mt-4 text-base leading-relaxed text-secondary/70 sm:text-lg">
            The most searched symbols on SymbolBuddy right now.
          </p>
        </div>

        <ul class="mt-12 grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-4">
          {
            popularSymbols.map((symbol) => (
              <li class="list-none">
                <SymbolCard
                  name={symbol.name}
                  slug={symbol.slug}
                  category={symbol.category}
                  meaning={symbol.meaning}
                  image={symbol.image}
                />
              </li>
            ))
          }
        </ul>
      </div>
    </section>

    <!-- How SymbolBuddy Helps -->
    <section class="px-4 py-16 sm:px-6 sm:py-20 lg:px-8" aria-labelledby="helps-heading">
      <div class="mx-auto max-w-6xl">
        <div class="mx-auto max-w-2xl text-center">
          <h2 id="helps-heading" class="font-heading text-3xl font-bold text-secondary sm:text-4xl">
            How SymbolBuddy Helps
          </h2>
        </div>

        <ul class="mt-12 grid grid-cols-1 gap-8 md:grid-cols-3">
          {
            helpFeatures.map((feature) => (
              <li class="list-none rounded-2xl border border-slate-200/80 bg-card p-8 text-center shadow-sm">
                <span class="inline-flex h-14 w-14 items-center justify-center rounded-2xl bg-primary/10 text-2xl" aria-hidden="true">
                  {feature.icon}
                </span>
                <h3 class="mt-5 font-heading text-xl font-bold text-secondary">
                  {feature.heading}
                </h3>
                <p class="mt-3 text-sm leading-relaxed text-secondary/70 sm:text-base">
                  {feature.text}
                </p>
              </li>
            ))
          }
        </ul>
      </div>
    </section>

    <!-- Why Trust SymbolBuddy -->
    <section class="bg-secondary px-4 py-16 sm:px-6 sm:py-20 lg:px-8" aria-labelledby="trust-heading">
      <div class="mx-auto max-w-6xl">
        <div class="mx-auto max-w-2xl text-center">
          <h2 id="trust-heading" class="font-heading text-3xl font-bold text-white sm:text-4xl">
            Why Trust SymbolBuddy
          </h2>
        </div>

        <ul class="mt-12 grid grid-cols-1 gap-6 sm:grid-cols-2">
          {
            trustPoints.map((point) => (
              <li class="list-none flex items-start gap-5 rounded-2xl border border-white/10 bg-white/5 p-6 sm:p-8">
                <span class="flex h-12 w-12 shrink-0 items-center justify-center rounded-xl bg-accent/20 text-xl" aria-hidden="true">
                  {point.icon}
                </span>
                <p class="font-heading text-lg font-bold leading-snug text-white sm:text-xl">
                  {point.text}
                </p>
              </li>
            ))
          }
        </ul>
      </div>
    </section>

    <!-- FAQ -->
    <section class="px-4 py-16 sm:px-6 sm:py-20 lg:px-8" aria-labelledby="faq-heading">
      <div class="mx-auto max-w-3xl">
        <div class="text-center">
          <h2 id="faq-heading" class="font-heading text-3xl font-bold text-secondary sm:text-4xl">
            Frequently Asked Questions
          </h2>
        </div>

        <div class="mt-10">
          <FAQAccordion faqs={faqs} client:visible />
        </div>
      </div>
    </section>

    <CTA />
  </main>

  <Footer />
</Layout>
