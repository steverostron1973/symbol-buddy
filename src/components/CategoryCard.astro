---
interface Props {
  title: string;
  description: string;
  slug: string;
  icon: string;
  count: number;
}

const { title, description, slug, icon, count } = Astro.props;
---

<a
  href={`/categories/${slug}`}
  class="group relative flex h-full flex-col overflow-hidden rounded-2xl border border-[#E2E8F0] border-l-4 border-l-[#2563EB] bg-white p-6 shadow-md transition-all duration-200 hover:scale-[1.02] hover:shadow-xl"
>
  <div
    class="pointer-events-none absolute inset-x-0 top-0 h-20 bg-gradient-to-b from-blue-50/90 to-transparent opacity-0 transition-opacity duration-200 group-hover:opacity-100"
    aria-hidden="true"
  ></div>

  <div class="relative mb-4 flex items-start justify-between gap-4">
    <span
      class="flex h-14 w-14 items-center justify-center rounded-full bg-gradient-to-br from-blue-50 to-blue-100 text-2xl"
      aria-hidden="true"
    >
      {icon}
    </span>
    <span class="rounded-full bg-[#EFF6FF] px-3 py-1 text-xs font-semibold text-[#2563EB]">
      {count} symbols
    </span>
  </div>

  <h3 class="relative font-heading text-xl font-bold text-[#0F172A] transition-colors group-hover:text-[#2563EB]">
    {title}
  </h3>

  <p class="relative mt-2 flex-1 text-sm leading-relaxed text-[#64748B]">
    {description}
  </p>

  <div class="relative mt-4 border-t border-[#E2E8F0] pt-4">
    <span class="inline-flex items-center gap-1 text-sm font-semibold text-[#2563EB]">
      Browse category
      <svg class="h-4 w-4 transition-transform duration-200 group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
      </svg>
    </span>
  </div>
</a>
