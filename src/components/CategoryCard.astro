---
interface Props {
  title: string;
  description: string;
  slug: string;
  icon: string;
  count: number;
}

const { title, description, slug, icon, count } = Astro.props;
---

<a
  href={`/categories/${slug}`}
  class="group flex h-full flex-col rounded-2xl border border-slate-200/80 bg-card p-6 shadow-sm transition-all duration-200 hover:-translate-y-0.5 hover:border-primary/20 hover:shadow-md"
>
  <div class="mb-4 flex items-start justify-between gap-4">
    <span class="text-3xl" aria-hidden="true">{icon}</span>
    <span class="rounded-full bg-primary/10 px-3 py-1 text-xs font-semibold text-primary">
      {count} symbols
    </span>
  </div>

  <h3 class="font-heading text-lg font-bold text-secondary transition-colors group-hover:text-primary">
    {title}
  </h3>

  <p class="mt-2 flex-1 text-sm leading-relaxed text-secondary/70">
    {description}
  </p>

  <span class="mt-4 inline-flex items-center gap-1 text-sm font-semibold text-primary">
    Browse category
    <svg class="h-4 w-4 transition-transform group-hover:translate-x-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
    </svg>
  </span>
</a>
