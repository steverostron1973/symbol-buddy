---
const footerLinks = [
  { label: 'Categories', href: '/categories' },
  { label: 'About', href: '/about' },
  { label: 'Contact', href: '/contact' },
  { label: 'Privacy', href: '/privacy' },
  { label: 'Terms', href: '/terms' },
];

const year = new Date().getFullYear();
---

<footer class="mt-auto border-t-2 border-[#2563EB] bg-[#0F172A]">
  <div class="mx-auto max-w-6xl px-4 py-12 sm:px-6 lg:px-8">
    <div class="flex flex-col gap-8 sm:flex-row sm:items-start sm:justify-between">
      <div class="max-w-sm">
        <a href="/" class="flex items-center gap-2">
          <img src="/logo.svg" alt="SymbolBuddy" width="48" height="48" class="h-12 w-12" />
          <span class="text-xl font-bold text-white">SymbolBuddy</span>
        </a>
        <p class="mt-3 text-sm leading-relaxed text-[#94A3B8]">
          Find out what any symbol means.
        </p>
      </div>

      <nav aria-label="Footer navigation">
        <ul class="flex flex-wrap gap-x-6 gap-y-3">
          {
            footerLinks.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="text-sm font-medium text-[#94A3B8] transition-colors hover:text-white"
                >
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>
    </div>

    <div class="mt-10 border-t border-white/10 pt-6">
      <p class="text-xs text-[#64748B]">
        &copy; {year} SymbolBuddy. All rights reserved.
      </p>
    </div>
  </div>
</footer>
