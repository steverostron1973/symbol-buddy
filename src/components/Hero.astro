---
import SearchBar from './SearchBar.jsx';

interface Props {
  headline: string;
  subheading: string;
}

const { headline, subheading } = Astro.props;

const popularSearches = [
  { label: 'Washing symbols', href: '/search?q=washing+symbols' },
  { label: 'Dashboard warning lights', href: '/search?q=dashboard+warning+lights' },
  { label: 'Hazard symbols', href: '/search?q=hazard+symbols' },
  { label: 'Keyboard shortcuts', href: '/search?q=keyboard+shortcuts' },
  { label: 'Recycling codes', href: '/search?q=recycling+codes' },
];
---

<section class="relative overflow-hidden bg-[#0F172A] px-4 py-32 sm:px-6 lg:px-8">
  <div
    class="pointer-events-none absolute inset-0 bg-[radial-gradient(ellipse_at_50%_0%,#1e3a5f_0%,#0F172A_70%)]"
    aria-hidden="true"
  ></div>
  <div
    class="pointer-events-none absolute inset-0 bg-[radial-gradient(circle,rgba(255,255,255,0.06)_1px,transparent_1px)] bg-[size:24px_24px]"
    aria-hidden="true"
  ></div>

  <div class="relative mx-auto max-w-4xl text-center">
    <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-[#2563EB]/30 bg-[#2563EB]/10 px-4 py-1.5">
      <span class="h-1.5 w-1.5 rounded-full bg-[#2563EB]" aria-hidden="true"></span>
      <span class="text-sm font-semibold text-[#2563EB]">The symbol reference</span>
    </div>

    <h1 class="font-heading text-6xl font-extrabold leading-tight tracking-tight text-white md:text-7xl">
      {headline}
    </h1>
    <p class="mx-auto mt-6 max-w-2xl text-lg leading-relaxed text-[#94A3B8] sm:text-xl">
      {subheading}
    </p>

    <div class="mx-auto mt-10 max-w-2xl">
      <SearchBar client:load />
    </div>

    <div class="mt-8">
      <p class="text-sm font-medium text-[#94A3B8]">Popular searches</p>
      <ul class="mt-3 flex flex-wrap items-center justify-center gap-2">
        {
          popularSearches.map((search) => (
            <li>
              <a
                href={search.href}
                class="inline-block rounded-full border border-white/30 bg-white/10 px-4 py-2 text-sm font-medium text-white transition-all hover:border-white/50 hover:bg-white/20"
              >
                {search.label}
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </div>
</section>
